{
  "name": "gutu-lib-form",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/form build",
    "typecheck": "bun run --cwd framework/libraries/form typecheck",
    "lint": "bun run --cwd framework/libraries/form lint",
    "test": "bun run --cwd framework/libraries/form test",
    "test:unit": "bun run --cwd framework/libraries/form test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
